{
  "name": "hutte",
  "description": "CLI for hutte.io",
  "version": "0.0.0-development",
  "author": "@hutte-io",
  "bugs": "https://github.com/hutte-io/hutte-sf-plugin/issues",
  "type": "module",
  "exports": "./lib/index.js",
  "dependencies": {
    "@inquirer/prompts": "^7.8.3",
    "@oclif/core": "^4.8.0",
    "@salesforce/core": "^8.26.2",
    "@salesforce/sf-plugins-core": "^12.2.6",
    "chalk": "^5.6.0",
    "cross-spawn": "^7.0.6",
    "fuse.js": "^7.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@salesforce/cli-plugins-testkit": "^5.3.39",
    "@salesforce/dev-scripts": "^11.0.3",
    "@types/cross-spawn": "^6.0.6",
    "@types/js-yaml": "^4.0.9",
    "eslint-plugin-sf-plugin": "^1.0.0",
    "oclif": "^4.14.29",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/lib",
    "/messages",
    "/oclif.manifest.json",
    "/oclif.lock"
  ],
  "homepage": "https://hutte.io",
  "keywords": [
    "sfdx-plugin",
    "sf-plugin"
  ],
  "license": "MIT",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "flexibleTaxonomy": true,
    "repositoryPrefix": "<%- repo %>/blob/main/<%- commandPath.replace('lib', 'src').replace('.js', '.ts') %>",
    "topics": {
      "hutte": {
        "description": "manage scratch orgs using Hutte"
      }
    },
    "additionalHelpFlags": [
      "-h"
    ]
  },
  "repository": "hutte-io/hutte-sf-plugin",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "wireit",
    "clean": "sf-clean",
    "clean-all": "sf-clean all",
    "compile": "wireit",
    "format": "wireit",
    "lint": "wireit",
    "prepare": "husky install",
    "postpack": "sf-clean --ignore-signing-artifacts",
    "prepack": "sf-prepack",
    "test": "wireit",
    "test:only": "wireit",
    "version": "oclif readme"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "compile",
        "lint"
      ]
    },
    "compile": {
      "command": "tsc -p . --pretty --incremental",
      "files": [
        "src/**/*.ts",
        "**/tsconfig.json",
        "messages/**"
      ],
      "output": [
        "lib/**",
        "*.tsbuildinfo"
      ],
      "clean": "if-file-deleted"
    },
    "format": {
      "command": "prettier --write \"+(src|test)/**/*.+(ts|js|json)\"",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        ".prettier*"
      ],
      "output": []
    },
    "lint": {
      "command": "eslint src test --color --cache --cache-location .eslintcache",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "messages/**",
        "**/.eslint*",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "test": {
      "dependencies": [
        "test:compile",
        "test:only",
        "lint"
      ]
    },
    "test:compile": {
      "command": "tsc -p \"./test\" --pretty",
      "files": [
        "test/**/*.ts",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "test:only": {
      "command": "nyc mocha \"test/**/*.test.ts\"",
      "env": {
        "FORCE_COLOR": "2"
      },
      "files": [
        "test/**/*.ts",
        "src/**/*.ts",
        "**/tsconfig.json",
        ".mocha*",
        ".nycrc"
      ],
      "output": []
    }
  }
}
